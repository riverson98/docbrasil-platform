{
  "Routes": [
    {
      "UpstreamPathTemplate": "/auth/{everything}",
      "DownstreamPathTemplate": "/api/Auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "associados-auth_service",
          "Port": 8080
        }
      ],
      "DelegatingHandlers": [ "AuthApiKeyHandler" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "ClientWhitelist": [ "admin" ],
        "Period": "10s",
        "Limit": 5
      },
      "HttpHandlerOptions": {
        "UseCookieContainer": true
      }
    },
    {
      "UpstreamPathTemplate": "/associado/{everything}",
      "DownstreamPathTemplate": "/api/Associado/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "associados_service",
          "Port": 8080
        }
      ],
      "DelegatingHandlers": [ "AssociadoApiKeyHandler" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "ClientWhitelist": [ "admin" ],
        "Period": "10s",
        "Limit": 5
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "UpstreamPathTemplate": "/endereco/{everything}",
      "DownstreamPathTemplate": "/api/Endereco/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
      {
        "Host": "associados_service",
        "Port": 8080
      }
      ],
      "DelegatingHandlers": [ "AssociadoApiKeyHandler" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "ClientWhitelist": [ "admin" ],
        "Period": "10s",
        "Limit": 5
      }
    }
  ],
  "GlobalConfiguration": {
    "RateLimitOptions": {
      "HttpStatusCode": 429,
      "QuotaExceededMessage": "Muitas requisições. Aguarde antes de tentar novamente.",
      "ClientIdHeader": "X-Client-Id"
    }
  }
}